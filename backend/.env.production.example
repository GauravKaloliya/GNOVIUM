FLASK_ENV=production
SECRET_KEY=replace-with-64-char-random-secret
JWT_SECRET_KEY=replace-with-different-64-char-random-secret
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=14
DATABASE_URL=postgresql://neondb_owner:password@ep-sparkling-block-aopwlv9r-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
REDIS_URL=redis://default:password@dear-raptor-34179.upstash.io:6379
CORS_ORIGINS=https://www.gnovium.com,https://*.vercel.app
ALLOWED_HOSTS=www.gnovium.com,*.vercel.app
RATELIMIT_DEFAULT=200 per minute
AUTO_CREATE_TABLES=false
REQUIRE_REDIS=true
DB_POOL_SIZE=1
DB_MAX_OVERFLOW=4
DB_POOL_RECYCLE=280
MAX_CONTENT_LENGTH=10485760
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.1
EMBEDDING_MODEL=nomic-embed-text
